# Database connection (Supabase PostgreSQL — JDBC format)
DATABASE_URL=jdbc:postgresql://host:port/postgres?user=USER&password=PASS&stringtype=unspecified&prepareThreshold=0

# Security (min 256 bits — generate with: openssl rand -hex 32)
JWT_SECRET=generate-with-openssl-rand-hex-32

# CORS (frontend origin)
CORS_ORIGINS=http://localhost:3000
