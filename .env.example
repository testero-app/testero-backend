# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# Database connection
# - dev: local Docker Compose (values below match docker-compose.yml)
# - prod: Supabase PostgreSQL JDBC URL
DATABASE_URL=jdbc:postgresql://localhost:5433/testero_dev?user=testero&password=testero

# Security (min 256 bits — generate with: openssl rand -hex 32)
JWT_SECRET=generate-with-openssl-rand-hex-32

# CORS (frontend origin)
CORS_ORIGINS=http://localhost:3000
